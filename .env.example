# FairMove — environment configuration
#
# Copy to .env.local and fill in what you have. FairMove runs a complete,
# honest demo with NONE of these set: it falls back to the simulated
# agent-to-agent market, which is an explicitly permitted counterparty setup.
#
# Never commit .env.local. Never put a real secret in this file.

# ---------------------------------------------------------------- ElevenLabs

# Required for any live voice work (interview widget or outbound calls).
ELEVENLABS_API_KEY=

# Agents. OPTIONAL — the in-app Settings page can create these with one click
# and stores the IDs in data/provider-config.json. Env values take precedence.
# Per-call variation is injected through dynamic variables, not by recreating agents.
ELEVENLABS_AGENT_ID_ESTIMATOR=
ELEVENLABS_AGENT_ID_CALLER=
ELEVENLABS_AGENT_ID_CLOSER=

# Provisioned Twilio/SIP number ID inside ElevenLabs. Required for PSTN calls.
ELEVENLABS_PHONE_NUMBER_ID=

# Shared secret for post-call webhook signature verification.
# Without it, webhooks are accepted unverified in development and REJECTED in production.
ELEVENLABS_WEBHOOK_SECRET=

# Optional overrides.
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_AGENT_LLM=gpt-4o

# ------------------------------------------------------------------ FairMove

# "simulation" | "elevenlabs". Unset auto-selects: elevenlabs when a key is
# present, simulation otherwise.
FAIRMOVE_MODE=

# Vertical config file loaded from ./verticals/<id>.json
FAIRMOVE_VERTICAL=moving

# Hard safety gate. Real phone calls to real businesses are placed ONLY when
# this is exactly "true" AND every ElevenLabs variable above is set. Leave unset.
FAIRMOVE_ALLOW_REAL_CALLS=

# ------------------------------------------------------------------ Optional

# Vision/OCR for photo and PDF document intake. Without it, document intake
# accepts text and typed inventories only, and says so rather than guessing.
OPENAI_API_KEY=

# Live business discovery for the call list. Without it, the call list comes
# from verticals/moving.json using the same schema shape.
GOOGLE_PLACES_API_KEY=
TAVILY_API_KEY=
